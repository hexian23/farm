<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaohe.farm_system.mapper.RoleMapper">
    <!-- 根据角色ID查询权限ID列表 -->
    <select id="selectRolePermissionIds" resultType="java.lang.Long">
        SELECT permission_id
        FROM sys_role_permission
        WHERE role_id = #{roleId}
    </select>
    <!-- 根据删除角色权限关系 -->
    <delete id="deleteRolePermissionByRoleIds">
        DELETE FROM sys_role_permission
        WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </delete>
    <!-- 批量插入角色权限关系 -->
    <insert id="insertRolePermission">
        INSERT INTO sys_role_permission(role_id, permission_id)
        VALUES
            <foreach collection="permissionIds" item="permissionId" separator=",">
                (#{roleId}, #{permissionId})
            </foreach>
    </insert>
    <!-- 批量删除角色-用户关系 -->
    <delete id="deleteUserRolesByRoleIds">
        DELETE FROM sys_user_role
        WHERE role_id IN
        <foreach collection="roleIds" item="roleId" separator=","  close=")">
            #{roleId}
        </foreach>
    </delete>
    <!-- 根据用户ID查询角色ID列表 -->
    <select id="selectRoleUserIds" resultType="java.lang.Long">
        SELECT user_id
        FROM sys_user_role
        WHERE role_id = #{roleId}
    </select>
    <!-- 根据角色Id和用户ID列表删除用户角色列表 -->
    <delete id="deleteUserRolesByRoleIdAndUserIds">
        DELETE FROM sys_user_role
        WHERE role_id = #{roleId}
        AND user_id IN
        <foreach collection="userId" item="userId" separator=","  close=")">
            #{userId}
        </foreach>
    </delete>
    <!-- 判断角色下是否存在用户 -->
    <select id="countUserRoleExists" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM sys_user_role
        WHERE role_id = #{roleId}
        AND user_id = #{userId}
    </select>
    <!-- 批量插入用户角色关系 -->
    <insert id="insertUserRole">
        INSERT INTO sys_user_role(role_id, user_id) VALUES(#{roleId}, #{userId})
    </insert>

</mapper>